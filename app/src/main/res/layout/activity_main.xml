<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// battery monitor"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="26sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/pctReadout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stateReadout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reading battery…"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/statusLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set a target and tap Start monitoring."
                android:textColor="@color/text_muted"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Controls card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notify me when charge reaches"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <SeekBar
                    android:id="@+id/targetSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="90"
                    android:progress="90"
                    android:progressTint="@color/amber"
                    android:thumbTint="@color/text_primary" />

                <TextView
                    android:id="@+id/targetNum"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:gravity="end" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alert method"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:layout_marginTop="20dp" />

            <RadioGroup
                android:id="@+id/modeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/modeBoth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Both"
                    android:textColor="@color/text_primary"
                    android:checked="true"
                    android:buttonTint="@color/lime" />

                <RadioButton
                    android:id="@+id/modeMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Message"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/lime" />

                <RadioButton
                    android:id="@+id/modeAlarm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Alarm"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/lime" />
            </RadioGroup>

            <Button
                android:id="@+id/toggleBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Start monitoring"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/bg"
                android:background="@drawable/bg_button_primary"
                android:padding="14dp" />

            <Button
                android:id="@+id/batteryOptBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Allow background running (recommended)"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:background="@android:color/transparent"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This runs as a background service, so it keeps checking and can alert you even with the app closed and the screen off. Tap “Allow background running” once so the system doesn't stop the service to save power."
                android:textColor="@color/text_muted"
                android:textSize="12.5sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
